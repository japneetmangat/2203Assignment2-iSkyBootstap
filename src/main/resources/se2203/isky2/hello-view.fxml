<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>


<StackPane prefHeight="600.0" prefWidth="850.0"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="se2203.isky2.HelloController">

    <ImageView fitWidth="850.0"
               fitHeight="600.0"
               preserveRatio="false"
               opacity="1.0">
        <image>
            <Image url="@WesternBackground.png"/>
        </image>
    </ImageView>

    <AnchorPane prefHeight="600.0" prefWidth="850.0">

        <children>

            <Label layoutX="63.0" layoutY="53.0" text="First-time setup">
                <font>
                    <Font name="System Bold" size="20.0"/>
                </font>
            </Label>

            <Label layoutX="63.0" layoutY="87.0"
                   text="This system is not initialized. Create the Master Account to continue."
                   textFill="RED">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <Label layoutX="63.0" layoutY="101.0"
                   text="Note: this setup screen will be disabled after initialization."
                   textFill="#6f6464">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <Separator layoutX="50.0" layoutY="127.0" prefWidth="700.0"/>

            <Label layoutX="63.0" layoutY="146.0" text="Master Account">
                <font>
                    <Font name="System Bold" size="13.0"/>
                </font>
            </Label>

            <Label layoutX="63.0" layoutY="177.0" text="Master username">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <TextField fx:id="MasterUsername"
                       layoutX="207.0" layoutY="171.0"
                       prefHeight="26.0" prefWidth="252.0"
                       promptText="e.g. isky-master">
                <font>
                    <Font size="11.0"/>
                </font>
            </TextField>

            <Label layoutX="207.0" layoutY="204.0"
                   text="Use a unique ID (no default credentials).">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <Label layoutX="63.0" layoutY="238.0" text="Contact email (optional)">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <TextField fx:id="ContactEmail"
                       layoutX="207.0" layoutY="233.0"
                       prefHeight="26.0" prefWidth="252.0"
                       promptText="e.g. name@isky.com">
                <font>
                    <Font size="11.0"/>
                </font>
            </TextField>

            <Label layoutX="207.0" layoutY="270.0"
                   text="Used for notifications in later tasks.">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <Label layoutX="63.0" layoutY="309.0" text="New Password">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <PasswordField fx:id="NewPasswordPF"
                           layoutX="207.0" layoutY="302.0"
                           prefHeight="26.0" prefWidth="252.0"
                           promptText="Enter a strong password">
                <font>
                    <Font size="11.0"/>
                </font>
            </PasswordField>

            <TextField fx:id="NewPasswordTF"
                       layoutX="207.0" layoutY="302.0"
                       prefHeight="26.0" prefWidth="252.0"
                       promptText="Enter a strong password"
                       visible="false" managed="false">
                <font>
                    <Font size="11.0"/>
                </font>
            </TextField>

            <CheckBox fx:id="Show1"
                      layoutX="480.0" layoutY="306.0"
                      mnemonicParsing="false" text="Show">
                <font>
                    <Font size="11.0"/>
                </font>
            </CheckBox>

            <Label layoutX="63.0" layoutY="350.0" text="Confirm Password">
                <font>
                    <Font size="11.0"/>
                </font>
            </Label>

            <PasswordField fx:id="ConfirmPasswordPF"
                           layoutX="207.0" layoutY="343.0"
                           prefHeight="26.0" prefWidth="252.0"
                           promptText="Re-enter password">
                <font>
                    <Font size="11.0"/>
                </font>
            </PasswordField>

            <TextField fx:id="ConfirmPasswordTF"
                       layoutX="207.0" layoutY="343.0"
                       prefHeight="26.0" prefWidth="252.0"
                       promptText="Re-enter password"
                       visible="false" managed="false">
                <font>
                    <Font size="11.0"/>
                </font>
            </TextField>

            <CheckBox fx:id="Show2"
                      layoutX="480.0" layoutY="347.0"
                      mnemonicParsing="false" text="Show">
                <font>
                    <Font size="11.0"/>
                </font>
            </CheckBox>

            <Pane layoutX="567.0" layoutY="160.0"
                  prefHeight="250.0" prefWidth="210.0"
                  style="-fx-background-color: lightyellow; -fx-border-color: black;">
                <children>
                    <Label layoutX="14.0" layoutY="14.0" text="Password Rules">
                        <font>
                            <Font name="System Bold" size="13.0"/>
                        </font>
                    </Label>

                    <Label fx:id="Characters"
                           layoutX="14.0" layoutY="39.0"
                           text="At least 12 characters"
                           textFill="#fc0606">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>

                    <Label fx:id="Common"
                           layoutX="14.0" layoutY="62.0"
                           text="Not a common/weak password"
                           textFill="#fc0606">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>

                    <Label fx:id="Same"
                           layoutX="14.0" layoutY="86.0"
                           text="Not the same as the username"
                           textFill="#fc0606">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>

                    <Label fx:id="Spaces"
                           layoutX="15.0" layoutY="111.0"
                           text="Spaces and special characters allowed"
                           textFill="#2cb22c">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>

                    <Label layoutX="16.0" layoutY="138.0"
                           prefHeight="26.0" prefWidth="177.0"
                           text="Tip: Use a passphrase (e.g. 4+ &#10;random words)">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>
                </children>
            </Pane>

            <Button fx:id="CreateMasterAccount"
                    layoutX="64.0" layoutY="397.0"
                    mnemonicParsing="false"
                    text="Create Master Account"
                    disable="true">
                <font>
                    <Font size="11.0"/>
                </font>
            </Button>

            <Button fx:id="Exit"
                    layoutX="197.0" layoutY="397.0"
                    mnemonicParsing="false"
                    text="Exit">
                <font>
                    <Font size="11.0"/>
                </font>
            </Button>

        </children>
    </AnchorPane>
</StackPane>